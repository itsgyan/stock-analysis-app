# ========================================================
# Environment Variables for Render (Production)
# 
# Render allows you to paste the contents of this file 
# directly into the "Environment Variables" section using 
# the "Add from .env" feature.
# ========================================================

# 1. Database Connection (Replace hostname and dbname with Render's PostgreSQL details)
SPRING_DATASOURCE_URL=jdbc:postgresql://<your-render-database-hostname>/<your-render-dbname>
SPRING_DATASOURCE_USERNAME=<your-render-database-user>
SPRING_DATASOURCE_PASSWORD=<your-render-database-password>

# 2. JWT Secret (Replace with a random, secure base64 string)
JWT_SECRET=my-super-secret-production-key-for-stock-analysis-api

# 3. Alpha Vantage API Key (Optional, replace 'demo' with your real key)
ALPHAVANTAGE_API_KEY=demo

# ========================================================
# Advanced / Performance Configurations
# ========================================================
# Enable real Alpha Vantage API calls instead of mock data
ALPHA_VANTAGE_LIVE_ENABLED=false

# Alpha Vantage timeouts (in milliseconds)
ALPHA_VANTAGE_CONNECT_TIMEOUT_MS=1500
ALPHA_VANTAGE_READ_TIMEOUT_MS=3000

# Logging & Debugging (Use true/DEBUG during local development)
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
APP_LOG_LEVEL=INFO
